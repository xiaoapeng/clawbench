<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="4dp">

    <!-- Protocol selector -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="协议"
        android:textColor="@color/dialog_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="6dp" />

    <RadioGroup
        android:id="@+id/protocolGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/protocolHttps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HTTPS"
            android:textColor="@color/dialog_text_primary"
            android:textSize="14sp"
            android:checked="true"
            android:buttonTint="@color/colorAccent" />

        <RadioButton
            android:id="@+id/protocolHttp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HTTP"
            android:textColor="@color/dialog_text_primary"
            android:textSize="14sp"
            android:layout_marginStart="24dp"
            android:buttonTint="@color/colorAccent" />
    </RadioGroup>

    <!-- Host + Port on one row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="服务器地址"
        android:textColor="@color/dialog_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/hostInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="192.168.1.100"
            android:inputType="textUri"
            android:singleLine="true"
            android:textColor="@color/dialog_text_primary"
            android:textColorHint="@color/dialog_text_hint"
            android:textSize="15sp"
            android:backgroundTint="@color/dialog_input_stroke_focused"
            android:paddingStart="12dp"
            android:paddingEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="@color/dialog_text_secondary"
            android:textSize="18sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <EditText
            android:id="@+id/portInput"
            android:layout_width="90dp"
            android:layout_height="44dp"
            android:text="20000"
            android:inputType="number"
            android:singleLine="true"
            android:textColor="@color/dialog_text_primary"
            android:textColorHint="@color/dialog_text_hint"
            android:textSize="15sp"
            android:backgroundTint="@color/dialog_input_stroke_focused"
            android:paddingStart="12dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <!-- Password -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="登录密码"
        android:textColor="@color/dialog_text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/passwordInput"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:hint="SSH / Web 认证密码"
        android:inputType="textPassword"
        android:singleLine="true"
        android:textColor="@color/dialog_text_primary"
        android:textColorHint="@color/dialog_text_hint"
        android:textSize="15sp"
        android:backgroundTint="@color/dialog_input_stroke_focused"
        android:paddingStart="12dp"
        android:paddingEnd="8dp" />

</LinearLayout>
