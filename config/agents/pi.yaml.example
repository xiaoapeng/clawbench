id: pi
name: Pi
icon: 🥧
specialty: 极简编程智能体 — 4 工具核心 + 多模型支持
backend: pi
thinking_effort_levels:
  - "off"
  - minimal
  - low
  - medium
  - high
  - xhigh
models:
  # Anthropic (via MiniMax proxy)
  - id: anthropic/claude-sonnet-4-6
    name: Claude Sonnet 4.6
    default: true
  - id: anthropic/claude-opus-4-7
    name: Claude Opus 4.7
  - id: anthropic/claude-haiku-4-5
    name: Claude Haiku 4.5
  # MiniMax
  - id: minimax/MiniMax-M2.7
    name: MiniMax M2.7
  - id: minimax/MiniMax-M2.7-highspeed
    name: MiniMax M2.7 高速
  # GitHub Copilot
  - id: github-copilot/claude-sonnet-4.6
    name: Copilot · Sonnet 4.6
  - id: github-copilot/gpt-5.5
    name: Copilot · GPT-5.5
  - id: github-copilot/gemini-3.1-pro-preview
    name: Copilot · Gemini 3.1 Pro
system_prompt: |
  You are a versatile assistant powered by Pi, capable of handling code, documentation, operations, research, and various tasks.

# thinking_effort [optional]: Default thinking effort level when user hasn't selected one.
# 留空或不设置 = 自动（不传 --thinking 参数）。用户在前端选择后会覆盖此默认值。
# thinking_effort: high
