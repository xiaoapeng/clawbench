# =============================================================================
# ClawBench Agent Configuration Example — CodeBuddy Backend
# ClawBench 智能体配置示例 — CodeBuddy 后端
# =============================================================================
#
# CodeBuddy CLI supports multiple models. Model lists are auto-discovered
# via `codebuddy --help` at runtime — no need to manually specify models.
# Users can switch between models in the chat UI (model switcher chip appears
# when models > 1).
# CodeBuddy CLI 支持多种模型。模型列表通过 `codebuddy --help` 在运行时自动发现
# —— 无需手动指定模型。用户可在聊天界面切换模型（模型数 > 1 时显示切换芯片）。
#
# This file is NOT loaded (the .yaml.example extension is ignored by LoadAgents).
# 本文件不会被加载（.yaml.example 后缀会被 LoadAgents 忽略）。
# To use, copy as e.g. my-codebuddy-agent.yaml and modify the config.
# 实际使用时请复制为如 my-codebuddy-agent.yaml 并修改配置。
# =============================================================================

id: codebuddy
name: CodeBuddy
icon: 🤖
specialty: CodeBuddy 驱动的通用助手
backend: codebuddy

# Models are auto-discovered via `codebuddy --help`. To override with a
# custom list, uncomment and edit. When user-defined models are present,
# they take priority over auto-discovered models and won't be overwritten
# by background refresh.
# models:
#   - id: glm-5.1
#     name: GLM 5.1
#     default: true
#   - id: glm-5.0
#     name: GLM 5.0
#   - id: kimi-k2.5
#     name: Kimi K2.5

system_prompt: |
  You are a versatile assistant powered by CodeBuddy, capable of handling code, documentation, operations, research, and various tasks.

# thinking_effort [optional]: Default thinking effort level when user hasn't selected one.
# 留空或不设置 = 自动（不传 --effort 参数）。用户在前端选择后会覆盖此默认值。
# thinking_effort: high

# --- Example: codebuddy-overseas dual-account instance ---
# Uses a separate `command` to access overseas/international models.
# Models must be listed manually since auto-discovery uses the default binary.
# id: codebuddy-overseas
# name: 海外版
# icon: 🔵
# specialty: CodeBuddy 海外版并行实例
# backend: codebuddy
# command: /home/user/codebuddy2
# models:
#   - id: gpt-5.5
#     name: GPT 5.5
#     default: true
#   - id: gpt-5.4
#     name: GPT 5.4
# system_prompt: |
#   You are a versatile assistant capable of handling code, documentation, operations, research, and various tasks.

# --- Example: Kimi 2.5 with vision capability ---
# id: designer
# name: 设计师
# icon: 🎨
# specialty: 界面设计与前端开发，Kimi 2.5 视觉识图
# backend: codebuddy
# models:
#   - id: kimi-k2.5
#     name: Kimi K2.5
#     default: true
#   - id: glm-5.1
#     name: GLM 5.1
# system_prompt: |
#   You are a UI design and frontend development expert powered by Kimi 2.5.
#   Kimi 2.5 has native vision capability — use the Read tool directly to read images.
#   Do not use mmx-cli for image analysis.
