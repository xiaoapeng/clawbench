# =============================================================================
# ClawBench Agent Configuration Example / 智能体配置示例
# =============================================================================
#
# This file is a complete reference for agent YAML configuration.
# 本文件是智能体 YAML 配置的完整参考。
#
# Each agent is defined in a .yaml file inside the agents/ directory.
# 每个智能体由 agents/ 目录下的 .yaml 文件定义。
# On startup, LoadAgents() scans the directory, reads all .yaml files, and registers agents.
# 启动时 LoadAgents() 会扫描该目录，读取所有 .yaml 文件并注册智能体。
#
# Loading process / 加载流程：
#   1. Read agent_common_prompt.md (in the parent directory) as the common prefix prompt
#      读取上级目录的 agent_common_prompt.md 作为公共前缀提示词
#   2. Parse each .yaml file → Agent struct
#      解析每个 .yaml 文件 → Agent 结构体
#   3. Prepend agent_common_prompt to each agent's system_prompt
#      将 agent_common_prompt 拼接到 system_prompt 前面
#   4. Replace {{AVAILABLE_AGENTS}} placeholder in system_prompt with the full agent list
#      替换 system_prompt 中的 {{AVAILABLE_AGENTS}} 占位符为所有智能体列表
#   5. Sort by ID alphabetically for deterministic ordering
#      按 ID 字母序排列后供前端和 API 使用
#
# ⚠️ This file is NOT loaded (the .yaml.example extension is ignored by LoadAgents).
#    本文件不会被加载（.yaml.example 后缀会被 LoadAgents 忽略）。
#    To use, copy as e.g. my-agent.yaml and modify the config.
#    实际使用时请复制为如 my-agent.yaml 并修改配置。
# =============================================================================

# ----- Required Fields / 必填字段 -----

# id [string, required]
# Unique identifier for the agent; must be globally unique across all agents.
# 智能体的唯一标识符，全局不可重复。
# Used in API routes, session association, and scheduled task agent assignment.
# 用于 API 路由、会话关联、定时任务指定执行者等场景。
# Naming convention: lowercase letters + digits + hyphens, short and meaningful.
# 命名建议：小写字母 + 数字 + 连字符，简短有意义。
id: claude-coder

# name [string, required]
# Display name shown in the frontend agent selector, session list, etc.
# 智能体的显示名称，展示在前端 UI 的智能体选择器、会话列表等位置。
name: Claude 编码

# icon [string, required]
# Agent icon as a single Emoji character.
# 智能体的图标，使用单个 Emoji 字符。
icon: 🟣

# specialty [string, required]
# One-line description of the agent's expertise / specialty.
# 智能体的专长/特长描述，一行简短文字。
# Shown in the frontend agent selector so users can quickly pick the right agent.
# 用于前端智能体选择器中展示该智能体擅长什么，帮助用户快速选择。
# Also injected into the {{AVAILABLE_AGENTS}} placeholder so other agents know each other's capabilities.
# 也会被注入到 {{AVAILABLE_AGENTS}} 占位符中，供其他智能体了解可用能力。
specialty: 复杂编码、架构设计、代码重构

# backend [string, required]
# AI backend type — determines which CLI tool is used to execute conversations.
# AI 后端类型，决定使用哪个 CLI 工具执行对话。
# Available values / 可选值：
#   - "claude"     → Claude Code CLI, supports AutoResume (detects ExitPlanMode, auto-sends "继续")
#   - "codebuddy"  → CodeBuddy CLI, supports AutoResume (same as above)
#   - "opencode"   → OpenCode CLI
#   - "gemini"     → Gemini CLI (Google Gemini)
#   - "codex"      → OpenAI Codex CLI
#   - "qoder"      → Qoder CLI (Alibaba), supports AutoResume (same as claude), auto model routing
backend: claude

# ----- Optional Fields / 可选字段 -----

# model [string, optional]
# Model identifier passed to the backend CLI.
# 传递给后端 CLI 的模型标识符。
# When omitted, the CLI uses its built-in default model.
# 省略时，CLI 使用其内置默认模型。
# Available values depend on the backend type and CLI tool version.
# 具体可用值取决于 backend 类型和 CLI 工具版本：
#   backend=claude    → "claude-sonnet-4-6", "claude-opus-4"
#   backend=codebuddy → "glm-5.1", "gpt-5.4", "gemini-3.1-pro", "kimi-k2.5"
#   backend=opencode  → "opencode/minimax-m2.5-free", "minimax-cn/MiniMax-M2.7"
#   backend=gemini    → "gemini-3.1-pro"
#   backend=codex     → "gpt-5.4"
#   backend=qoder     → "auto" (default, auto-routing), or specific model names
model: claude-sonnet-4-6

# system_prompt [string, optional]
# The agent's system prompt / role definition.
# 智能体的系统提示词 / 角色设定。
# When omitted, the agent uses only agent_common_prompt.md as its system prompt.
# 省略时，智能体仅使用 agent_common_prompt.md 作为系统提示词。
# When set, agent_common_prompt.md content is automatically prepended.
# 设置后，加载时会自动在前面拼接 agent_common_prompt.md 的内容。
# Supports multi-line text using YAML | (preserve newlines) or > (fold newlines) syntax.
# 支持多行，使用 YAML 的 |（保留换行）或 >（折叠换行）语法。
# You may use the placeholder {{AVAILABLE_AGENTS}}, which is replaced at load time with the
# list of all agent IDs and their specialties.
# 可使用占位符 {{AVAILABLE_AGENTS}}，运行时会被替换为所有智能体的 ID 和专长列表。
system_prompt: |
  You are an expert software engineer specializing in complex coding, architecture design, and code refactoring.
  You write clean, maintainable code and provide thorough explanations of your design decisions.

  Available agents on this platform:
  {{AVAILABLE_AGENTS}}

# command [string, optional]
# Custom CLI executable path or command (with optional arguments).
# 自定义 CLI 可执行文件路径或命令。
# When not set, the backend's default CLI command is used (e.g. claude, codebuddy, opencode, etc.).
# 不设置时，使用后端默认的 CLI 命令（如 claude、codebuddy、opencode 等）。
# When set, it overrides the default command. Useful for:
# 设置后，会覆盖默认命令，适用于：
#   - Using a different version of the CLI (e.g. /home/user/codebuddy2)
#   - Passing CLI startup arguments (e.g. "codex --profile m27")
#   - Using a CLI installed at a custom path
#command: /home/user/claude-local
